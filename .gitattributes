# Handle line endings automatically for files detected as text 
# and leave binary files untouched.
* text=auto

# Standardize line endings to LF for source files
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
